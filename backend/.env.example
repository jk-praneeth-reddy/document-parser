NODE_ENV=development
# Local default; Render injects PORT — do not set PORT in Render dashboard unless you know you need to.
PORT=8000
# Optional bind address (default 0.0.0.0 so the app accepts traffic in Docker/Render)
# HOST=0.0.0.0

# CORS — comma-separated origins (no trailing slashes). Required for browser calls from your deployed frontend.
# Local:
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
# Production example (replace with your real frontend URL(s)):
# CORS_ORIGINS=https://your-app.onrender.com,https://www.yourdomain.com

# OpenAI — required for OCR extraction (set in Render: Environment → add OPENAI_API_KEY)
OPENAI_API_KEY=sk-...

# Notes for Render / cloud:
# - SQLite (data/history.db) and uploads/ live on ephemeral disk unless you add a Render Disk — they reset on redeploy.
# - After deploy, use your service URL as the frontend VITE_API_BASE_URL (see frontend/.env.example).
